---
interface Props {
  text: string
  variant?: 'note' | 'tip' | 'caution' | 'danger' | 'success'
}

const { text, variant = 'note' } = Astro.props

const colors = {
  note: 'bg-blue-500/10 text-blue-700 border-blue-500/20 dark:text-blue-400',
  tip: 'bg-sky-500/10 text-sky-700 border-sky-500/20 dark:text-sky-400',
  caution: 'bg-yellow-500/10 text-yellow-700 border-yellow-500/20 dark:text-yellow-400',
  danger: 'bg-red-500/10 text-red-700 border-red-500/20 dark:text-red-400',
  success: 'bg-green-500/10 text-green-700 border-green-500/20 dark:text-green-400',
}
---

<span class={`inline-block px-2 py-0.5 rounded-full text-xs font-bold border ${colors[variant]}`}>
  {text}
</span>
