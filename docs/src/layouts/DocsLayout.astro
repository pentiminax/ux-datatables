---
import Layout from './Layout.astro'
import { docsSidebarSections } from '../config/navigation'

interface Props {
  title: string
  description?: string
}

const { title, description } = Astro.props
const pathname = Astro.url.pathname
---

<Layout title={title} description={description}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-8 py-8 md:flex-row">
      <!-- Sidebar -->
      <aside class="w-full shrink-0 md:w-64">
        <nav class="sticky top-24 max-h-[calc(100vh-7rem)] space-y-8 overflow-y-auto pb-8">
          {
            docsSidebarSections.map((section) => (
              <div>
                <h3 class="mb-3 text-sm font-semibold tracking-wider text-slate-600 uppercase dark:text-slate-500">
                  {section.label}
                </h3>
                <ul class="space-y-2">
                  {section.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class:list={[
                          'block border-l-2 pl-4 text-sm transition-colors',
                          pathname === item.href
                            ? 'border-blue-500 text-slate-900 dark:text-white'
                            : 'border-transparent text-slate-600 dark:text-slate-400 hover:border-blue-500 hover:text-slate-900 dark:hover:text-white',
                        ]}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </nav>
      </aside>

      <!-- Content -->
      <article class="prose prose-blue dark:prose-invert max-w-none flex-grow">
        <slot />
      </article>
    </div>
  </div>
</Layout>

<style is:global>
  @reference '../styles/global.css';
  .prose h1 {
    @apply mb-8 text-4xl;
  }
  .prose h2 {
    @apply mt-12 mb-6 border-b border-slate-200 dark:border-slate-800 pb-2 text-2xl;
  }
  .prose h3 {
    @apply mt-8 mb-4 text-xl;
  }

  /* Heading anchors */
  .prose h2,
  .prose h3,
  .prose h4 {
    position: relative;
    scroll-margin-top: 5rem;
  }
  .prose .heading-anchor {
    @apply ml-2 text-slate-400 dark:text-slate-600 no-underline opacity-0 transition-opacity;
    font-weight: normal;
  }
  .prose h2:hover .heading-anchor,
  .prose h3:hover .heading-anchor,
  .prose h4:hover .heading-anchor {
    @apply opacity-100;
  }
  .prose .heading-anchor:hover {
    @apply text-blue-400;
  }
  .prose p {
    @apply mb-4 leading-relaxed text-slate-600 dark:text-slate-400;
  }
  .prose code {
    @apply rounded bg-slate-200 px-1.5 py-0.5 font-mono text-sm text-blue-700 dark:bg-slate-800 dark:text-blue-300;
  }
  .prose pre {
    @apply my-6 overflow-x-auto rounded-lg border border-slate-800 bg-slate-900 p-4;
  }
  .prose pre code {
    @apply bg-transparent p-0 text-slate-300;
  }
  .prose ul {
    @apply mb-4 list-inside list-disc space-y-2 text-slate-600 dark:text-slate-400;
  }
  .prose ol {
    @apply mb-4 list-inside list-decimal space-y-2 text-slate-600 dark:text-slate-400;
  }
  .prose strong {
    @apply font-semibold text-slate-900 dark:text-white;
  }
  .prose a {
    @apply text-blue-600 underline decoration-slate-300 underline-offset-4 transition-all hover:text-blue-700 hover:decoration-blue-400 dark:text-blue-400 dark:decoration-slate-700 dark:hover:text-blue-300;
  }
  .prose table {
    @apply my-6 w-full text-left text-sm;
    border-collapse: collapse;
    display: block;
    overflow-x: auto;
  }
  .prose thead tr {
    @apply bg-slate-100 dark:bg-slate-900/70;
  }
  .prose th {
    @apply border-b border-slate-300 px-4 py-3 font-semibold text-slate-900 dark:border-slate-700 dark:text-slate-100;
  }
  .prose td {
    @apply border-b border-slate-200 px-4 py-3 align-top text-slate-700 dark:border-slate-800 dark:text-slate-300;
  }
  .prose tbody tr:nth-child(even) {
    @apply bg-slate-100/60 dark:bg-slate-900/30;
  }
  .prose tbody tr:hover {
    @apply bg-blue-500/10;
  }

  /* Sidebar scrollbar */
  aside nav::-webkit-scrollbar {
    width: 4px;
  }
  aside nav::-webkit-scrollbar-track {
    background: transparent;
  }
  aside nav::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 2px;
  }
  aside nav::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
  aside nav {
    scrollbar-width: thin;
    scrollbar-color: #cbd5e1 transparent;
  }
  .dark aside nav::-webkit-scrollbar-thumb {
    background: #1e293b;
  }
  .dark aside nav::-webkit-scrollbar-thumb:hover {
    background: #334155;
  }
  .dark aside nav {
    scrollbar-color: #1e293b transparent;
  }
</style>
